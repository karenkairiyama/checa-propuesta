{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "logo/**",
              "ui_kits/site/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Outfit|Outfit Variable|Cormorant Garamond))/i]",
        "message": "Font not provided by the design system. Available: Outfit, Outfit Variable, Cormorant Garamond."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--kk-bg",
      "--kk-bg-2",
      "--kk-cream",
      "--kk-dur-base",
      "--kk-dur-curtain",
      "--kk-dur-fast",
      "--kk-dur-slow",
      "--kk-dur-theme",
      "--kk-ease",
      "--kk-ease-in-out",
      "--kk-ease-out",
      "--kk-fg",
      "--kk-glow",
      "--kk-hover",
      "--kk-ink",
      "--kk-leading-body",
      "--kk-leading-display",
      "--kk-leading-snug",
      "--kk-leading-tight",
      "--kk-overlay",
      "--kk-press",
      "--kk-radius-0",
      "--kk-radius-hair",
      "--kk-radius-pill",
      "--kk-recess",
      "--kk-rule",
      "--kk-sans",
      "--kk-serif",
      "--kk-smoke",
      "--kk-space-1",
      "--kk-space-10",
      "--kk-space-11",
      "--kk-space-2",
      "--kk-space-3",
      "--kk-space-4",
      "--kk-space-5",
      "--kk-space-6",
      "--kk-space-7",
      "--kk-space-8",
      "--kk-space-9",
      "--kk-text-2xl",
